<?xml version="1.0"?>
<Container version="2">
  <Name>unraid-docker-monitor</Name>
  <Repository>ghcr.io/wildfirebill-docker/unraid-docker-monitor:latest</Repository>
  <Registry>ghcr.io</Registry>
  <Network>bridge</Network>
  <WebUI>http://[IP]:[PORT:5000]</WebUI>
  <Category>Other:</Category>
  <Overview>A real-time monitoring dashboard for Docker containers, designed for Unraid but works anywhere with Docker.</Overview>
  <Project>https://github.com/wildfirebill-docker/unraid-docker-monitor</Project>
  <Author>wildfirebill</Author>
  <Support>https://github.com/wildfirebill-docker/unraid-docker-monitor/issues</Support>
  <TemplateURL>https://github.com/wildfirebill-unraid/Unraid_Templates_By_Me/blob/fec35d4fded1d3ac8671b77bed3500d59e670a68/templates/tools/unraid-docker-monitor.xml</TemplateURL>
  <Icon>https://raw.githubusercontent.com/wildfirebill-docker/unraid-docker-monitor/refs/heads/main/icon.svg</Icon>
  <Shell>bash</Shell>
  <Privileged>false</Privileged>
  <ExtraParams></ExtraParams>
  <PostArgs></PostArgs>
  <Config Name="WebUI" Target="5000" Default="5000" Mode="tcp" Description="WebUI Port" Type="Port" Display="always" Required="true" Mask="false">5000</Config>
  <Config Name="DOCKER_HOST" Target="DOCKER_HOST" Default="unix:///var/run/docker.sock" Mode="" Description="Specify the value for env: DOCKER_HOST" Type="Variable" Display="always" Required="true" Mask="false">unix:///var/run/docker.sock</Config>
  <Config Name="Volume for /var/run/docker.sock" Target="/var/run/docker.sock" Default="/var/run/docker.sock" Mode="rw" Description="E.g. /mnt/appdata/unraid-docker-monitor for config and /mnt/data/ for other volumes" Type="Path" Display="always" Required="true" Mask="false"></Config>
</Container>
