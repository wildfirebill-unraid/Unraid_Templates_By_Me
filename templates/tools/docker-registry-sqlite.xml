<?xml version="1.0" encoding="utf-8"?>
<Container>
  <Name>docker-registry-sqlite</Name>
  <Description>Private Docker Registry with Multi-User Support and Modern Web UI (SQLite Version)</Description>
  <Registry>docker pull ghcr.io/wildfirebill-docker/docker-registry-sqlite:main</Registry>
  <Repository>wildfirebill/docker-registry-sqlite</Repository>
  <Vendor></Vendor>
  <SupportURL>https://github.com/wildfirebill-docker/docker-registry-sqlite/issues</SupportURL>
  <ProjectURL>https://github.com/wildfirebill-docker/docker-registry-sqlite</ProjectURL>
  <Icon>https://raw.githubusercontent.com/docker-library/docs/master/docker-logo.png</Icon>
  <Categories>
    <Category>Utilities</Category>
    <Category>Network:Web</Category>
  </Categories>
  <Video/>
  <WebUI>http://[IP]:[PORT:8080]/</WebUI>
  <ExtraParameters>
    <Param name="TZ" Label="Timezone" default="UTC" type="text" required="false" description="Container timezone (e.g., America/New_York)"/>
  </ExtraParameters>
  <Environment>
    <Param name="PORT" Label="Web Port" default="8080" type="number" required="true"/>
    <Param name="DB_DRIVER" Label="Database Driver" default="sqlite" type="select" required="true" options="sqlite,mysql,mariadb" description="Database driver to use"/>
    <Param name="DB_HOST" Label="External DB Host" default="" type="text" required="false" description="External database host (leave empty for SQLite)"/>
    <Param name="DB_PORT" Label="External DB Port" default="3306" type="number" required="false" description="External database port"/>
    <Param name="DB_USER" Label="External DB User" default="" type="text" required="false" description="External database username"/>
    <Param name="DB_PASSWORD" Label="External DB Password" default="" type="password" required="false" description="External database password"/>
    <Param name="DB_NAME" Label="External DB Name" default="registry" type="text" required="false" description="External database name"/>
    <Param name="DB_SOURCE" Label="Database Source (override)" default="/data/registry.db" type="text" required="false" description="Full DSN string (overrides individual DB_* variables)"/>
    <Param name="JWT_SECRET" Label="JWT Secret" default="change-this-secret-in-production" type="text" required="true" description="Secret key for JWT tokens - CHANGE THIS!"/>
    <Param name="ADMIN_USERNAME" Label="Admin Username" default="admin" type="text" required="true"/>
    <Param name="ADMIN_PASSWORD" Label="Admin Password" default="admin123" type="password" required="true" description="CHANGE THIS PASSWORD IMMEDIATELY"/>
    <Param name="ADMIN_EMAIL" Label="Admin Email" default="admin@localhost" type="text" required="false"/>
    <Param name="HTTPS_ENABLED" Label="HTTPS Enabled" default="false" type="select" required="false" options="true,false" description="Set to true if running behind HTTPS proxy"/>
  </Environment>
  <Labels>
    <Label name="net.unraid.docker.icon" value="docker-logo.png"/>
  </Labels>
  <ConfigFile>config/unraid-sqlite.xml</ConfigFile>
  <Privileges/>
</Container>
