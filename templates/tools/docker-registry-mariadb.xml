<?xml version="1.0"?>
<Container version="2">
  <Name>docker-registry-mariadb</Name>
  <Repository>ghcr.io/wildfirebill-docker/docker-registry-mariadb:main</Repository>
  <Registry>ghcr.io/wildfirebill-docker/docker-registry-mariadb:main</Registry>
  <Network>custom</Network>
  <MyIP></MyIP>
  <Shell>sh</Shell>
  <Privileged>false</Privileged>
  <Support>https://github.com/wildfirebill-docker/docker-registry-mariadb/issues</Support>
  <Project>https://github.com/wildfirebill-docker/docker-registry-mariadb</Project>
  <ReadMe/>
  <Overview>Private Docker Registry with Multi-User Support and Modern Web UI (MariaDB Version)</Overview>
  <Beta>True</Beta>
  <Category>Network:Web Network:Other Tools:</Category>
  <WebUI>http://[IP]:[PORT:8080]/</WebUI>
  <TemplateURL>https://github.com/wildfirebill-unraid/Unraid_Templates_By_Me/blob/6ac2d4f45c2173b0bc6420fe0e9e291cf75ab74c/templates/tools/docker-registry-mariadb.xml</TemplateURL>
  <Icon>https://raw.githubusercontent.com/docker-library/docs/master/docker-logo.png</Icon>
  <ExtraParams>--always-restrart</ExtraParams>
  <PostArgs/>
  <CPUset/>
  <Date>2026-04-07</Date>
  <DonateText/>
  <DonateLink/>
  <Requires>MariaDB / MySQL database installed</Requires>
  <Config Name="PORT" Target="8080" Default="8080" Type="Port" Mode="tcp" Display="always" Required="true" Description="Web port"/>
  <Config Name="DB_HOST" Target="External DB Host" Default="mariadb" Type="Variable" Display="always" Required="true" Description="Database host (use 'mariadb' for bundled, or external IP/hostName)"/>
  <Config Name="DB_PORT" Target="External DB Port" Default="3306" Type="Variable" Display="always" Required="true" Description="Database port"/>
  <Config Name="DB_USER" Target="Database User" Default="root" Type="Variable" Display="always" Required="true" Description="Database username"/>
  <Config Name="DB_PASSWORD" Target="Database Password" Default="registry_root_password" Type="Variable" Display="always" Required="true" Description="Database password"/>
  <Config Name="DB_Name" Target="Database Name" Default="registry" Type="Variable" Display="always" Required="true" Description="Database Name"/>
  <Config Name="JWT_SECRET" Target="JWT Secret" Default="change-this-secret-in-production" Type="Variable" Display="always" Required="true" Description="Secret key for JWT tokens - CHANGE THIS! (Not Recommended to use outside sources.) https://jwtsecrets.com/#generator "/>
  <Config Name="ADMIN_USERNAME" Target="Admin Username" Default="admin" Type="Variable" Display="always" Required="true" Description="Admin Username"/>
  <Config Name="ADMIN_PASSWORD" Target="Admin Password" Default="admin123" Type="Variable" Display="always" Required="true" Description="CHANGE THIS PASSWORD IMMEDIATELY"/>
  <Config Name="ADMIN_EMAIL" Target="Admin Email" Default="admin@localhost" Type="Variable" Display="always" Required="false" Description="Admin Email"/>
  <Config Name="TZ" Target="Timezone" Default="UTC" Type="Variable" Display="always" Required="false" Description="Container timezone (e.g., America/New_York)"/>
  <Config Name="DB_DRIVER" Target="Database Driver" Default="mysql" Type="Variable" Display="advanced"/>
  <Config Name="HTTPS_ENABLED" Target="HTTPS Enabled" Default="false" Type="Variable" Display="advanced-hide" Required="false" Options="false|true" Description="Set to true if running behind HTTPS proxy"/>
  <Config Name="DB_SOURCE" Target="Database Source (override)" Default="" Type="Variable" Display="advanced-hide" Required="false" Description="Full DSN string (overrides individual DB_* variables)"/>
</Container>
