<?xml version="1.0" encoding="utf-8"?>
<Container>
  <Name>docker-registry-mariadb</Name>
  <Description>Private Docker Registry with Multi-User Support and Modern Web UI (MariaDB Version)</Description>
  <Registry>ghcr.io/wildfirebill-docker/docker-registry-mariadb:main</Registry>
  <Repository>ghcr.io/wildfirebill-docker/docker-registry-mariadb:main</Repository>
  <Vendor></Vendor>
  <SupportURL>https://github.com/wildfirebill-docker/docker-registry-mariadb/issues</SupportURL>
  <ProjectURL>https://github.com/wildfirebill-docker/docker-registry-mariadb</ProjectURL>
  <Icon>https://raw.githubusercontent.com/docker-library/docs/master/docker-logo.png</Icon>
  <Categories>
    <Category>Utilities</Category>
    <Category>Network:Web</Category>
  </Categories>
  <Video/>
  <WebUI>http://[IP]:[PORT:8080]/</WebUI>
  <ExtraConfigeters>
    
  </ExtraConfigeters>
  <Environment>
    <Config name="PORT" Label="Web Port" default="8080" type="number" required="true"/>
    <Config name="DB_DRIVER" Label="Database Driver" default="mysql" type="hidden"/>
    <Config name="DB_HOST" Label="External DB Host" default="mariadb" type="text" required="true" description="Database host (use 'mariadb' for bundled, or external IP/hostname)"/>
    <Config name="DB_PORT" Label="External DB Port" default="3306" type="number" required="true" description="Database port"/>
    <Config name="DB_USER" Label="Database User" default="root" type="text" required="true" description="Database username"/>
    <Config name="DB_PASSWORD" Label="Database Password" default="registry_root_password" type="password" required="true" description="Database password"/>
    <Config name="DB_NAME" Label="Database Name" default="registry" type="text" required="true" description="Database name"/>
    <Config name="DB_SOURCE" Label="Database Source (override)" default="" type="text" required="false" description="Full DSN string (overrides individual DB_* variables)"/>
    <Config name="JWT_SECRET" Label="JWT Secret" default="change-this-secret-in-production" type="text" required="true" description="Secret key for JWT tokens - CHANGE THIS!"/>
    <Config name="ADMIN_USERNAME" Label="Admin Username" default="admin" type="text" required="true"/>
    <Config name="ADMIN_PASSWORD" Label="Admin Password" default="admin123" type="password" required="true" description="CHANGE THIS PASSWORD IMMEDIATELY"/>
    <Config name="ADMIN_EMAIL" Label="Admin Email" default="admin@localhost" type="text" required="false"/>
    <Config name="HTTPS_ENABLED" Label="HTTPS Enabled" default="false" type="select" required="false" options="true,false" description="Set to true if running behind HTTPS proxy"/>
    <Config name="TZ" Label="Timezone" default="UTC" type="text" required="false" description="Container timezone (e.g., America/New_York)"/>
  </Environment>
  <Labels>
    <Label name="net.unraid.docker.icon" value="docker-logo.png"/>
  </Labels>
  <ConfigFile>config/unraid-mariadb.xml</ConfigFile>
  <Privileges/>
</Container>
