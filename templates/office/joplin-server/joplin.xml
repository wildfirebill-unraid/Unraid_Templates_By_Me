<?xml version="1.0"?>
<Container version="2">
  <Name>joplin-server</Name>
  <Repository>joplin/server</Repository>
  <Registry>https://hub.docker.com/r/joplin/server</Registry>
  <Network>bridge</Network>
  <WebUI>http://[IP]:[PORT:22300]</WebUI>
  <Category>Notes:</Category>
  <Overview>Joplin Server - self-hosted sync server for Joplin notes app.&lt;br&gt;&lt;br&gt;Template generated using comp2unraid.</Overview>
  <Project>https://joplinapp.org/</Project>
  <Author>Joplin</Author>
  <Support>https://github.com/laurent22/joplin/issues</Support>
  <Icon>https://raw.githubusercontent.com/joplin/assetRefs/master/favicon/favicon-256x256.png</Icon>
  <Shell>bash</Shell>
  <Privileged>false</Privileged>
  <ExtraParams></ExtraParams>
  <PostArgs></PostArgs>
  <Config Name="WebUI Port" Target="22300" Default="22300" Mode="tcp" Description="Joplin web UI port" Type="Port" Display="always" Required="true" Mask="false">22300</Config>
  <Config Name="DB_CLIENT" Target="DB_CLIENT" Default="pg" Mode="" Description="Database client" Type="Variable" Display="always" Required="true" Mask="false">pg</Config>
  <Config Name="POSTGRES_HOST" Target="POSTGRES_HOST" Default="joplin-postgres" Mode="" Description="PostgreSQL host" Type="Variable" Display="always" Required="true" Mask="false">joplin-postgres</Config>
  <Config Name="POSTGRES_PORT" Target="POSTGRES_PORT" Default="5432" Mode="" Description="PostgreSQL port" Type="Variable" Display="always" Required="true" Mask="false">5432</Config>
  <Config Name="POSTGRES_DATABASE" Target="POSTGRES_DATABASE" Default="joplin" Mode="" Description="Database name" Type="Variable" Display="always" Required="true" Mask="false">joplin</Config>
  <Config Name="POSTGRES_USER" Target="POSTGRES_USER" Default="joplin" Mode="" Description="Database user" Type="Variable" Display="always" Required="true" Mask="false">joplin</Config>
  <Config Name="POSTGRES_PASSWORD" Target="POSTGRES_PASSWORD" Default="joplinpassword" Mode="" Description="Database password" Type="Variable" Display="always" Required="true" Mask="true">joplinpassword</Config>
  <Config Name="APP_BASE_URL" Target="APP_BASE_URL" Default="http://localhost:22300" Mode="" Description="Base URL" Type="Variable" Display="always" Required="true" Mask="false">http://localhost:22300</Config>
  <Config Name="APP_PORT" Target="APP_PORT" Default="22300" Mode="" Description="App port" Type="Variable" Display="always" Required="true" Mask="false">22300</Config>
  <Config Name="MAILER_ENABLED" Target="MAILER_ENABLED" Default="0" Mode="" Description="Enable mailer" Type="Variable" Display="always" Required="true" Mask="false">0</Config>
</Container>