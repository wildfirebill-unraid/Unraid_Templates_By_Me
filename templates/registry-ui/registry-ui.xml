<?xml version="1.0"?>
<Container version="2">
  <Name>registry-ui</Name>
  <Repository>wildfirebill/registry-ui:latest</Repository>
  <Registry>https://hub.docker.com/r/wildfirebill/registry-ui</Registry>
  <Network>bridge</Network>
  <MyIP></MyIP>
  <Shell>sh</Shell>
  <Privileged>false</Privileged>
  <Support>https://github.com/wildfirebill-nintendo-dev/zed/registry-ui</Support>
  <Project>https://github.com/wildfirebill-nintendo-dev/zed/registry-ui</Project>
  <Overview>A Docker Registry UI for browsing and managing Docker images and tags.</Overview>
  <Category>Docker Registry: Tools</Category>
  <WebUI>http://[IP]:[PORT:8000]/</WebUI>
  <Icon>https://raw.githubusercontent.com/quiquest/registry-ui/main/static/favicon.ico</Icon>
  <ExtraParams></ExtraParams>
  <PostArgs></PostArgs>
  <CPUset></CPUset>
  <DateInstalled>1711804800</DateInstalled>

  <Config Name="Web UI Port" Target="8000" Default="8181" Mode="tcp" Description="Port for accessing the Registry UI web interface" Type="Port" Display="always" Required="true">8181</Config>

  <Config Name="Config File Path" Target="/opt/config.yml" Default="" Mode="rw" Description="Path to the registry-ui config.yml file on the host" Type="Path" Display="always" Required="true">/mnt/user/appdata/registry-ui/config.yml</Config>

  <Config Name="Data Path" Target="/opt/data" Default="" Mode="rw" Description="Path to store registry-ui data (SQLite database)" Type="Path" Display="always" Required="true">/mnt/user/appdata/registry-ui/data</Config>
</Container>
