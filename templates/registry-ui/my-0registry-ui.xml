<?xml version="1.0"?>
<Container version="2">
  <Name>registry-ui</Name>
  <Repository>ghcr.io/wildfirebill-docker/registry-ui:master</Repository>
  <Registry>https://github.com/wildfirebill-docker/registry-ui/pkgs/container/registry-ui/766804828?tag=master</Registry>
  <Network>bridge</Network>
  <MyIP></MyIP>
  <Shell>sh</Shell>
  <Privileged>false</Privileged>
  <Support>https://github.com/wildfirebill-docker/registry-ui/issues</Support>
  <Project>https://github.com/wildfirebill-docker/registry-ui/</Project>
  <Overview>A Docker Registry UI for browsing and managing Docker images and tags.</Overview>
  <Requires>https://github.com/wildfirebill-unraid/Unraid_Templates_By_Me/blob/c139c2035ff160c0af2b717172d44f01c86a77c3/templates/registry-ui/config.yml</Requires>
  <Category>Docker Registry: Tools</Category>
  <WebUI>http://[IP]:[PORT:8000]/</WebUI>
  <TemplateURL>https://github.com/wildfirebill-unraid/Unraid_Templates_By_Me/blob/c139c2035ff160c0af2b717172d44f01c86a77c3/templates/registry-ui/registry-ui.xml</TemplateURL>
  <Icon>https://raw.githubusercontent.com/wildfirebill-docker/registry-ui/refs/heads/master/static/favicon.ico</Icon>
  <ExtraParams>--restart unless-stopped</ExtraParams>
  <PostArgs></PostArgs>
  <CPUset></CPUset>
  <DateInstalled>1711804800</DateInstalled>

  <Config Name="Web UI Port" Target="8000" Default="8181" Mode="tcp" Description="Port for accessing the Registry UI web interface" Type="Port" Display="always" Required="true">8181</Config>

  <Config Name="Config File Path" Target="/opt/config.yml" Default="" Mode="rw" Description="Path to the registry-ui config.yml file on the host" Type="Path" Display="always" Required="true">/mnt/user/appdata/registry-ui/config.yml</Config>

  <Config Name="Data Path" Target="/opt/data" Default="" Mode="rw" Description="Path to store registry-ui data (SQLite database)" Type="Path" Display="always" Required="true">/mnt/user/appdata/registry-ui/data</Config>
</Container>
